     <widget class="QWidget" name="tabWiki">
      <attribute name="title">
       <string>Wiki</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_wiki">
       <item>
        <widget class="QTextEdit" name="wikiTextEdit">
         <property name="readOnly">
          <bool>true</bool>
         </property>
         <property name="html">
          <string>&lt;!DOCTYPE html&gt;
&lt;html&gt;
&lt;head&gt;
&lt;style&gt;
  body { font-family: 'Segoe UI', Arial, sans-serif; margin: 15px; line-height: 1.5; color: #333; background: #fafafa; }
  h1 { color: #2c3e50; border-bottom: 2px solid #4ecdc4; padding-bottom: 8px; font-size: 20px; }
  h2 { color: #34495e; margin-top: 18px; border-left: 3px solid #4ecdc4; padding-left: 12px; font-size: 16px; }
  h3 { color: #2c3e50; margin-top: 12px; font-size: 14px; }
  .badge { background: #4ecdc4; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px; display: inline-block; margin: 1px; }
  .support-box { background: #fff5f5; padding: 12px; border-radius: 6px; border-left: 3px solid #e74c3c; margin: 12px 0; }
  table { width: 100%; border-collapse: collapse; margin: 8px 0; font-size: 13px; }
  th { background: #4ecdc4; color: white; padding: 5px 8px; text-align: left; }
  td { border: 1px solid #ddd; padding: 5px 8px; }
  tr:nth-child(even) { background: #f8f8f8; }
  .note { background: #fff8e1; padding: 8px 12px; border-radius: 4px; border-left: 3px solid #ffc107; margin: 8px 0; font-size: 13px; }
  ul, ol { margin: 3px 0; padding-left: 20px; }
  li { margin: 2px 0; }
  .version { color: #7f8c8d; font-size: 13px; }
  hr { margin: 15px 0; border: none; border-top: 1px solid #eee; }
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;h1&gt;Universal Map2web&lt;/h1&gt;
&lt;p class="version"&gt;&lt;strong&gt;Version :&lt;/strong&gt; 1.0.0 | &lt;strong&gt;QGIS :&lt;/strong&gt; 3.16+&lt;/p&gt;

&lt;p&gt;Extension QGIS pour exporter des couches vectorielles en &lt;strong&gt;cartes HTML interactives&lt;/strong&gt; avec préservation de la symbologie QGIS.&lt;/p&gt;

&lt;h2&gt;Fonctionnalités&lt;/h2&gt;
&lt;ul&gt;
  &lt;li&gt;1 Export multi-couches avec styles QGIS (couleurs, épaisseurs, opacités)&lt;/li&gt;
  &lt;li&gt;2 Conservation des étiquettes (labeling) et légende automatique&lt;/li&gt;
  &lt;li&gt;3 Fonds de plan : OSM, Google Satellite, Hybrid ou personnalisé&lt;/li&gt;
  &lt;li&gt;4 Outils : géolocalisation, mesure, recherche, plein écran, minimap, impression&lt;/li&gt;
  &lt;li&gt;5 Filtrage avancé par attribut (8 opérateurs)&lt;/li&gt;
  &lt;li&gt;6 4 thèmes visuels : Clair, Sombre, Professionnel, Coloré&lt;/li&gt;
  &lt;li&gt;7 Regroupement des points (clustering)&lt;/li&gt;
  &lt;li&gt;8 Configuration des popups par couche&lt;/li&gt;
&lt;/ul&gt;

&lt;h2&gt;Manuel rapide&lt;/h2&gt;

&lt;h3&gt;1. Lancement&lt;/h3&gt;
&lt;p&gt;Cliquez sur l'icône &lt;strong&gt;Universal Map2web&lt;/strong&gt; dans la barre d'outils QGIS.&lt;/p&gt;

&lt;h3&gt;2. Export&lt;/h3&gt;
&lt;ol&gt;
  &lt;li&gt;Sélectionnez les &lt;strong&gt;couches&lt;/strong&gt; à exporter (onglet Couches)&lt;/li&gt;
  &lt;li&gt;Configurez les &lt;strong&gt;popups&lt;/strong&gt; (champs à afficher au clic)&lt;/li&gt;
  &lt;li&gt;Choisissez le &lt;strong&gt;fond de plan&lt;/strong&gt; et le &lt;strong&gt;thème&lt;/strong&gt;&lt;/li&gt;
  &lt;li&gt;Personnalisez : &lt;strong&gt;titre&lt;/strong&gt;, &lt;strong&gt;logo&lt;/strong&gt;, &lt;strong&gt;couleur d'en-tête&lt;/strong&gt;&lt;/li&gt;
  &lt;li&gt;Activez les &lt;strong&gt;outils&lt;/strong&gt; souhaités&lt;/li&gt;
  &lt;li&gt;Cliquez sur &lt;strong&gt;"OK"&lt;/strong&gt; et choisissez le dossier de destination&lt;/li&gt;
  &lt;li&gt;La carte s'ouvre automatiquement dans le navigateur&lt;/li&gt;
&lt;/ol&gt;

&lt;h3&gt;3. Navigation web&lt;/h3&gt;
&lt;table&gt;
  &lt;tr&gt;&lt;th&gt;Action&lt;/th&gt;&lt;th&gt;Commande&lt;/th&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Zoom&lt;/td&gt;&lt;td&gt;Molette / + / -&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Déplacer&lt;/td&gt;&lt;td&gt;Clic-glisser&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Voir attributs&lt;/td&gt;&lt;td&gt;Clic sur l'élément&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Réinitialiser vue&lt;/td&gt;&lt;td&gt;Double-clic sur la carte&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;

&lt;h3&gt;4. Filtrage avancé&lt;/h3&gt;
&lt;p&gt;Dans la barre latérale de la carte : sélectionnez &lt;strong&gt;couche&lt;/strong&gt; → &lt;strong&gt;champ&lt;/strong&gt; → &lt;strong&gt;opérateur&lt;/strong&gt; → saisissez la &lt;strong&gt;valeur&lt;/strong&gt; → &lt;strong&gt;Appliquer&lt;/strong&gt;.&lt;/p&gt;
&lt;p&gt;Opérateurs disponibles : &lt;span class="badge"&gt;=&lt;/span&gt; &lt;span class="badge"&gt;≠&lt;/span&gt; &lt;span class="badge"&gt;contient&lt;/span&gt; &lt;span class="badge"&gt;commence par&lt;/span&gt; &lt;span class="badge"&gt;&amp;gt;&lt;/span&gt; &lt;span class="badge"&gt;&amp;lt;&lt;/span&gt; &lt;span class="badge"&gt;≥&lt;/span&gt; &lt;span class="badge"&gt;≤&lt;/span&gt;&lt;/p&gt;

&lt;h3&gt;5. Gestion des couches sur la carte&lt;/h3&gt;
&lt;ul&gt;
  &lt;li&gt;&lt;strong&gt;Afficher/Masquer&lt;/strong&gt; : cocher/décocher dans la légende&lt;/li&gt;
  &lt;li&gt;&lt;strong&gt;Clustering&lt;/strong&gt; : activer "Regrouper les points" (couches ponctuelles)&lt;/li&gt;
  &lt;li&gt;&lt;strong&gt;Légende&lt;/strong&gt; : affichage automatique des catégories et couleurs&lt;/li&gt;
&lt;/ul&gt;

&lt;h2&gt;Configuration requise&lt;/h2&gt;
&lt;table&gt;
  &lt;tr&gt;&lt;th&gt;Composant&lt;/th&gt;&lt;th&gt;Configuration&lt;/th&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;QGIS&lt;/td&gt;&lt;td&gt;3.16 ou supérieure&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Navigateur&lt;/td&gt;&lt;td&gt;Chrome 90+, Firefox 88+, Edge 90+&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Mémoire&lt;/td&gt;&lt;td&gt;4 Go RAM minimum&lt;/td&gt;&lt;/tr&gt;
  &lt;tr&gt;&lt;td&gt;Connexion&lt;/td&gt;&lt;td&gt;Internet (fonds de plan et librairies)&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;

&lt;h2&gt;Bonnes pratiques&lt;/h2&gt;
&lt;div class="note"&gt;
  &lt;ul&gt;
    &lt;li&gt;Limitez à &lt;strong&gt;10 couches actives&lt;/strong&gt; maximum pour des performances optimales&lt;/li&gt;
    &lt;li&gt;Fichiers recommandés &lt;strong&gt;&amp;lt; 50 Mo&lt;/strong&gt; par couche&lt;/li&gt;
    &lt;li&gt;Utilisez le système &lt;strong&gt;WGS84 (EPSG:4326)&lt;/strong&gt; pour vos données&lt;/li&gt;
    &lt;li&gt;Testez l'affichage dans QGIS avant l'export&lt;/li&gt;
  &lt;/ul&gt;
&lt;/div&gt;

&lt;h2&gt;Support technique&lt;/h2&gt;
&lt;div class="support-box"&gt;
  &lt;p&gt;&lt;strong&gt;Jean-Baptiste KIBORA&lt;/strong&gt;&lt;/p&gt;
  &lt;p&gt;📧 &lt;strong&gt;Email&lt;/strong&gt; : jeanbaptiste.kibora@tic.gov.bf&lt;/p&gt;
  &lt;p&gt;📱 &lt;strong&gt;Téléphone&lt;/strong&gt; : +226 64 41 25 14&lt;/p&gt;
&lt;/div&gt;

&lt;hr&gt;
&lt;p style="text-align: center; color: #7f8c8d; font-size: 11px;"&gt;
  Universal Map2web v1.0.0 | © kibora B. Jean-Baptiste | Juillet 2026
&lt;/p&gt;

&lt;/body&gt;
&lt;/html&gt;</string>
         </property>
        </widget>
       </item>
      </layout>
     </widget>
    </widget>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
